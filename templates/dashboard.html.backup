<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XRAG Professional - Real Engineering Charts</title>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary: #00ff88;
            --primary-dark: #00cc66;
            --secondary: #D4AF37;
            --danger: #ff4444;
            --warning: #ffaa00;
            --info: #4a90e2;
            --dark: #0a0a0a;
            --darker: #050505;
            --light: #1a1a1a;
            --text: #ffffff;
            --text-dim: #888888;
            --border: #333333;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--darker);
            color: var(--text);
            line-height: 1.6;
        }
        
        @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
            canvas { 
                image-rendering: crisp-edges;
                min-width: 1920px;
                min-height: 1080px;
            }
        }
        
        .dashboard {
            max-width: 1920px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 30px;
            background: linear-gradient(135deg, var(--dark), var(--darker));
            border: 1px solid var(--primary);
            border-radius: 12px;
            margin-bottom: 20px;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .logo img {
            height: 60px;
            width: 60px;
            filter: drop-shadow(0 0 10px var(--primary));
        }
        
        .logo h1 {
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--text), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .status-bar {
            display: flex;
            gap: 30px;
            padding: 10px 25px;
            background: var(--dark);
            border-radius: 30px;
            border: 1px solid var(--primary);
        }
        
        .status-item {
            text-align: right;
        }
        
        .status-label {
            font-size: 12px;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .status-value {
            font-size: 18px;
            font-weight: 700;
        }
        
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
        }
        
        .tab {
            padding: 10px 25px;
            cursor: pointer;
            border-radius: 20px;
            color: var(--text-dim);
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .tab:hover {
            background: var(--light);
            color: var(--text);
        }
        
        .tab.active {
            background: var(--light);
            color: var(--primary);
            border: 1px solid var(--primary);
        }
        
        .pipeline {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            padding: 15px;
            background: var(--dark);
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        
        .stage {
            flex: 1;
            text-align: center;
            padding: 10px;
            position: relative;
        }
        
        .stage:not(:last-child)::after {
            content: '→';
            position: absolute;
            right: -10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            font-size: 20px;
        }
        
        .stage-number {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
        }
        
        .stage-name {
            font-size: 12px;
            color: var(--text-dim);
        }
        
        .stage.active .stage-number {
            color: var(--secondary);
        }
        
        .stage.completed .stage-number {
            color: var(--primary-dark);
        }
        
        .grid {
            display: grid;
            grid-template-columns: 320px 1fr 320px;
            gap: 20px;
        }
        
        .panel {
            background: var(--dark);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }
        
        .panel-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
        }
        
        .domain-list {
            list-style: none;
            max-height: 400px;
            overflow-y: auto;
        }
        
        .domain-item {
            padding: 10px 12px;
            margin-bottom: 4px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            border: 1px solid transparent;
            transition: all 0.2s;
        }
        
        .domain-item:hover {
            background: var(--light);
            border-color: var(--primary);
        }
        
        .domain-item.active {
            background: var(--light);
            border-color: var(--primary);
            color: var(--primary);
        }
        
        .count {
            background: var(--darker);
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            color: var(--text-dim);
        }
        
        .chart-container {
            width: 100%;
            height: 350px;
            background: var(--darker);
            border: 1px solid var(--border);
            border-radius: 8px;
            margin-bottom: 20px;
            position: relative;
            cursor: crosshair;
        }
        
        .chart-container::after {
            content: '🔍 Click to enlarge';
            position: absolute;
            bottom: 10px;
            right: 15px;
            color: var(--primary);
            font-size: 11px;
            background: rgba(0,0,0,0.6);
            padding: 4px 10px;
            border-radius: 20px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .chart-container:hover::after {
            opacity: 1;
        }
        
        canvas {
            width: 100% !important;
            height: 100% !important;
            display: block;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        
        .data-table th {
            text-align: left;
            padding: 10px;
            color: var(--primary);
            border-bottom: 2px solid var(--border);
            font-weight: 600;
        }
        
        .data-table td {
            padding: 8px 10px;
            border-bottom: 1px solid var(--border);
        }
        
        .data-table tr:hover {
            background: var(--light);
        }
        
        .pass { color: var(--primary); font-weight: 600; }
        .fail { color: var(--danger); font-weight: 600; }
        .warning { color: var(--warning); font-weight: 600; }
        
        .upasl-panel {
            background: linear-gradient(135deg, var(--dark), #1a1a1a);
            border-left: 4px solid var(--secondary);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        
        .upasl-title {
            color: var(--secondary);
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .constraint-item {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }
        
        .constraint-value {
            color: var(--primary);
            font-weight: 600;
        }
        
        .analysis-card {
            background: var(--light);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            border: 1px solid var(--border);
        }
        
        .analysis-title {
            color: var(--text-dim);
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        
        .analysis-value {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary);
        }
        
        .analysis-unit {
            color: var(--text-dim);
            font-size: 12px;
            margin-left: 5px;
        }
        
        .param-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 15px;
        }
        
        .param-item {
            background: var(--darker);
            padding: 10px;
            border-radius: 6px;
            text-align: center;
        }
        
        .param-label {
            font-size: 11px;
            color: var(--text-dim);
        }
        
        .param-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--primary);
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            backdrop-filter: blur(5px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            background: var(--dark);
            border: 2px solid var(--primary);
            border-radius: 16px;
            padding: 25px;
            width: 95%;
            max-width: 3840px;
            height: 95%;
            display: flex;
            flex-direction: column;
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border);
        }
        
        .modal-title {
            font-size: 24px;
            color: var(--primary);
        }
        
        .modal-close {
            font-size: 36px;
            cursor: pointer;
            color: var(--text-dim);
            transition: color 0.3s;
        }
        
        .modal-close:hover {
            color: var(--danger);
        }
        
        .modal-body {
            flex: 1;
            min-height: 0;
        }
        
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: var(--darker);
        }
        
        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 4px;
        }
        
        .engineering-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 20px;
        }
        
        .pq-curve, .emi-spectrum, .eye-diagram, .pulse-analysis {
            height: 200px;
            background: var(--darker);
            border: 1px solid var(--border);
            border-radius: 8px;
            position: relative;
        }
        
        @media (max-width: 1400px) {
            .grid {
                grid-template-columns: 280px 1fr 280px;
            }
        }
        
        @media (max-width: 1200px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="header">
            <div class="logo">
                <img src="/static/aichip-logo.png" alt="AICHIP">
                <div>
                    <h1>XRAG Professional</h1>
                    <div style="color: var(--text-dim); font-size: 12px;">Real Engineering Charts • CISPR 25 • USB 2.0 • ISO 5801</div>
                </div>
            </div>
            <div class="status-bar">
                <div class="status-item">
                    <div class="status-label">CORE</div>
                    <div class="status-value">5-Stage</div>
                </div>
                <div class="status-item">
                    <div class="status-label">GEO</div>
                    <div class="status-value">3D GNN</div>
                </div>
                <div class="status-item">
                    <div class="status-label">WORLD</div>
                    <div class="status-value">Digital Twin</div>
                </div>
                <div class="status-item">
                    <div class="status-label">CAUSAL</div>
                    <div class="status-value">Matrix</div>
                </div>
            </div>
        </div>
        
        <div class="tabs">
            <div class="tab active" onclick="switchTab('core')">XRAG Core</div>
            <div class="tab" onclick="switchTab('geo')">GEO 3D GNN</div>
            <div class="tab" onclick="switchTab('world')">WORLD Digital Twin</div>
            <div class="tab" onclick="switchTab('causal')">CAUSAL Matrix</div>
            <div class="tab" onclick="switchTab('statistical')">Statistical Analysis</div>
            <div class="tab" onclick="switchTab('engineering')">Engineering</div>
        </div>
        
        <div class="pipeline">
            <div class="stage completed" id="stage-l1">
                <div class="stage-number">L1</div>
                <div class="stage-name">Characterization</div>
            </div>
            <div class="stage completed" id="stage-l2">
                <div class="stage-number">L2</div>
                <div class="stage-name">Pathway Gen</div>
            </div>
            <div class="stage active" id="stage-l3">
                <div class="stage-number">L3</div>
                <div class="stage-name">Feasibility</div>
            </div>
            <div class="stage" id="stage-l4">
                <div class="stage-number">L4</div>
                <div class="stage-name">Calibration</div>
            </div>
            <div class="stage" id="stage-l5">
                <div class="stage-number">L5</div>
                <div class="stage-name">Explainability</div>
            </div>
        </div>
        
        <div class="grid">
            <div class="panel">
                <div class="panel-title">
                    DOMAINS
                    <span class="count" id="domain-count">8</span>
                </div>
                <ul class="domain-list" id="domain-list"></ul>
                
                <div class="panel-title" style="margin-top: 20px;">
                    CATEGORIES
                </div>
                <ul class="domain-list" id="category-list">
                    <li class="domain-item">Select a domain</li>
                </ul>
                
                <div class="panel-title" style="margin-top: 20px;">
                    FORMULAS
                    <span class="count" id="formula-count">0</span>
                </div>
                <div class="domain-list" id="formula-list" style="max-height: 200px;"></div>
            </div>
            
            <div class="panel">
                <div id="core-view">
                    <div class="chart-container" id="core-chart" onclick="openModal('core')">
                        <canvas id="core-canvas"></canvas>
                    </div>
                    
                    <div class="param-grid">
                        <div class="param-item">
                            <div class="param-label">Overshoot</div>
                            <div class="param-value" id="overshoot">4.2%</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Undershoot</div>
                            <div class="param-value" id="undershoot">3.5%</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Rise Time</div>
                            <div class="param-value" id="rise-time">85 ps</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Fall Time</div>
                            <div class="param-value" id="fall-time">92 ps</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Jitter</div>
                            <div class="param-value" id="jitter">3.2 ps</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">SNR</div>
                            <div class="param-value" id="snr">18.4 dB</div>
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;">
                        <div class="chart-container" style="height: 200px;" onclick="openModal('rsi')">
                            <canvas id="rsi-canvas"></canvas>
                        </div>
                        <div class="chart-container" style="height: 200px;" onclick="openModal('ema')">
                            <canvas id="ema-canvas"></canvas>
                        </div>
                    </div>
                    
                    <table class="data-table" style="margin-top: 20px;">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Measured</th>
                                <th>Limit</th>
                                <th>Standard</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="parameter-table">
                            <tr><td>Rise Time (20-80%)</td><td>85 ps</td><td><100 ps</td><td>USB 2.0</td><td class="pass">PASS</td></tr>
                            <tr><td>Fall Time (80-20%)</td><td>92 ps</td><td><100 ps</td><td>USB 2.0</td><td class="pass">PASS</td></tr>
                            <tr><td>Overshoot</td><td>4.2%</td><td><5%</td><td>PCIe Gen3</td><td class="pass">PASS</td></tr>
                            <tr><td>Undershoot</td><td>3.5%</td><td><5%</td><td>PCIe Gen3</td><td class="pass">PASS</td></tr>
                            <tr><td>Jitter (RMS)</td><td>3.2 ps</td><td><5 ps</td><td>USB 3.0</td><td class="pass">PASS</td></tr>
                            <tr><td>SNR</td><td>18.4 dB</td><td>>15 dB</td><td>CISPR 25</td><td class="pass">PASS</td></tr>
                        </tbody>
                    </table>
                </div>
                
                <div id="geo-view" style="display: none;">
                    <div class="chart-container" id="geo-container" style="height: 500px;"></div>
                    
                    <div style="display: flex; gap: 20px; margin-top: 15px;">
                        <div style="flex: 1;">
                            <div class="param-label">Nodes</div>
                            <div class="param-value" id="geo-nodes">0</div>
                        </div>
                        <div style="flex: 1;">
                            <div class="param-label">Edges</div>
                            <div class="param-value" id="geo-edges">0</div>
                        </div>
                        <div style="flex: 1;">
                            <div class="param-label">Communities</div>
                            <div class="param-value" id="geo-communities">0</div>
                        </div>
                    </div>
                </div>
                
                <div id="world-view" style="display: none;">
                    <div class="chart-container" id="world-container" style="height: 400px;"></div>
                    
                    <div style="margin-top: 20px;">
                        <div style="margin-bottom: 15px;">
                            <div style="display: flex; justify-content: space-between;">
                                <span>Temperature</span>
                                <span id="world-temp-display">50°C</span>
                            </div>
                            <input type="range" id="world-temp" min="0" max="100" value="50" style="width: 100%;">
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>Pressure</span>
                                <span id="world-pressure-display">30%</span>
                            </div>
                            <input type="range" id="world-pressure" min="0" max="100" value="30" style="width: 100%;">
                        </div>
                    </div>
                </div>
                
                <div id="causal-view" style="display: none;">
                    <div class="chart-container" onclick="openModal('causal')">
                        <canvas id="causal-canvas"></canvas>
                    </div>
                    
                    <div style="display: flex; gap: 20px; margin-top: 20px;">
                        <div style="flex: 1; text-align: center;">
                            <div class="param-label">ATE</div>
                            <div class="param-value" id="causal-ate">0.92</div>
                        </div>
                        <div style="flex: 1; text-align: center;">
                            <div class="param-label">ATT</div>
                            <div class="param-value" id="causal-att">0.87</div>
                        </div>
                        <div style="flex: 1; text-align: center;">
                            <div class="param-label">p-value</div>
                            <div class="param-value" id="causal-p">0.001</div>
                        </div>
                    </div>
                </div>
                
                <div id="statistical-view" style="display: none;">
                    <div class="chart-container" onclick="openModal('correlation')">
                        <canvas id="correlation-canvas"></canvas>
                    </div>
                    
                    <div class="param-grid">
                        <div class="param-item">
                            <div class="param-label">Mean</div>
                            <div class="param-value" id="stat-mean">72.4</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Std Dev</div>
                            <div class="param-value" id="stat-std">8.3</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Skewness</div>
                            <div class="param-value" id="stat-skew">0.12</div>
                        </div>
                        <div class="param-item">
                            <div class="param-label">Kurtosis</div>
                            <div class="param-value" id="stat-kurt">2.8</div>
                        </div>
                    </div>
                </div>
                
                <div id="engineering-view" style="display: none;">
                    <div class="engineering-grid">
                        <div class="pq-curve" id="pq-curve"></div>
                        <div class="emi-spectrum" id="emi-spectrum"></div>
                    </div>
                    <div class="engineering-grid" style="margin-top: 15px;">
                        <div class="eye-diagram" id="eye-diagram"></div>
                        <div class="pulse-analysis" id="pulse-analysis"></div>
                    </div>
                </div>
            </div>
            
            <div class="panel">
                <div class="upasl-panel">
                    <div class="upasl-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M12 2L2 7v10l10 5 10-5V7l-10-5z" stroke="#D4AF37" stroke-width="2"/>
                            <path d="M12 12l4-2v6l-4 2-4-2v-6l4 2z" stroke="#D4AF37" stroke-width="2"/>
                        </svg>
                        UPASL INTERFACE
                    </div>
                    <div class="constraint-item">
                        <span>Domain</span>
                        <span class="constraint-value" id="upasl-domain">physics</span>
                    </div>
                    <div class="constraint-item">
                        <span>Material</span>
                        <span class="constraint-value" id="upasl-material">copper</span>
                    </div>
                    <div class="constraint-item">
                        <span>Temperature</span>
                        <span class="constraint-value" id="upasl-temp">[-50, 500] °C</span>
                    </div>
                    <div class="constraint-item">
                        <span>Constraints</span>
                        <span class="constraint-value" id="upasl-count">3/5</span>
                    </div>
                </div>
                
                <div class="analysis-card">
                    <div class="analysis-title">EXECUTIVE SUMMARY</div>
                    <div id="executive-summary">
                        Physics domain: Ideal gas analysis complete. R²=0.998
                    </div>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px;">
                    <div class="analysis-card" style="padding: 12px;">
                        <div class="analysis-title">R²</div>
                        <div class="analysis-value" id="metric-r2">0.998</div>
                    </div>
                    <div class="analysis-card" style="padding: 12px;">
                        <div class="analysis-title">SNR</div>
                        <div class="analysis-value" id="metric-snr">18.4</div>
                        <span class="analysis-unit">dB</span>
                    </div>
                    <div class="analysis-card" style="padding: 12px;">
                        <div class="analysis-title">THD</div>
                        <div class="analysis-value" id="metric-thd">2.3</div>
                        <span class="analysis-unit">%</span>
                    </div>
                    <div class="analysis-card" style="padding: 12px;">
                        <div class="analysis-title">Jitter</div>
                        <div class="analysis-value" id="metric-jitter">3.2</div>
                        <span class="analysis-unit">ps</span>
                    </div>
                </div>
                
                <div class="analysis-card">
                    <div class="analysis-title">RECOMMENDATIONS</div>
                    <ul style="margin-left: 20px; color: var(--text-dim);" id="recommendations-list">
                        <li>✓ All USB 2.0 timing margins met</li>
                        <li>✓ CISPR 25 Class 5 compliance achieved</li>
                        <li>⚠️ Consider ferrite bead on power line</li>
                        <li>ℹ Additional thermal characterization recommended</li>
                    </ul>
                </div>
                
                <div class="upasl-panel" style="margin-top: 15px;">
                    <div class="upasl-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="3" width="18" height="18" rx="2" stroke="#00ff88" stroke-width="2"/>
                            <path d="M8 8h8v8H8z" stroke="#00ff88" stroke-width="2"/>
                        </svg>
                        IMS STORAGE
                    </div>
                    <button onclick="exportFreezePackage()" style="width:100%; padding:10px; background:var(--primary); color:var(--dark); border:none; border-radius:6px; font-weight:600; cursor:pointer;">
                        Export Freeze Package
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="modal" id="modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title" id="modal-title">Enlarged View</span>
                <span class="modal-close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body" id="modal-body">
                <canvas id="modal-canvas" style="width:100%; height:100%;"></canvas>
            </div>
        </div>
    </div>

    <script>
        // ==================== REAL GNN FOR XRAG ====================

        class XRAG_GNN {
            constructor() {
                this.nodes = [];
                this.edges = [];
                this.nodeFeatures = [];
                this.nodeEmbeddings = [];
                this.communities = [];
                this.adjacencyMatrix = [];
                this.degreeMatrix = [];
                this.laplacian = [];
                
                // GNN hyperparameters
                this.inputDim = 128;
                this.hiddenDim = 64;
                this.outputDim = 32;
                this.numLayers = 3;
                this.dropout = 0.2;
                
                // Weights (simulated for visualization)
                this.W1 = this.randomMatrix(this.inputDim, this.hiddenDim);
                this.W2 = this.randomMatrix(this.hiddenDim, this.hiddenDim);
                this.W3 = this.randomMatrix(this.hiddenDim, this.outputDim);
            }
            
            // Initialize from signal data
            buildFromSignal(signal, sampleRate = 1000) {
                console.log("Building graph from signal...");
                
                // 1. Segment signal into nodes (sliding windows)
                const windowSize = 64;
                const stride = 8;
                this.createNodesFromSignal(signal, windowSize, stride);
                
                // 2. Extract features from each node
                this.extractNodeFeatures(signal, sampleRate);
                
                // 3. Build k-NN graph based on feature similarity
                this.buildKNNGraph(15); // k=15 nearest neighbors
                
                // 4. Compute graph properties
                this.computeGraphProperties();
                
                // 5. Run community detection
                this.detectCommunities();
                
                // 6. Generate 3D embeddings for visualization
                this.generateEmbeddings();
                
                console.log(`Graph built: ${this.nodes.length} nodes, ${this.edges.length} edges`);
                return {
                    nodes: this.nodes.length,
                    edges: this.edges.length,
                    communities: this.communities.length
                };
            }
            
            // Create nodes from signal segments
            createNodesFromSignal(signal, windowSize, stride) {
                this.nodes = [];
                for (let i = 0; i + windowSize < signal.length; i += stride) {
                    this.nodes.push({
                        id: this.nodes.length,
                        startIdx: i,
                        endIdx: i + windowSize,
                        segment: signal.slice(i, i + windowSize)
                    });
                }
            }
            
            // Extract features from each node
            extractNodeFeatures(signal, sampleRate) {
                this.nodeFeatures = this.nodes.map(node => {
                    const segment = node.segment;
                    
                    // Statistical features
                    const mean = segment.reduce((a,b) => a + b, 0) / segment.length;
                    const variance = segment.reduce((a,b) => a + Math.pow(b - mean, 2), 0) / segment.length;
                    const std = Math.sqrt(variance);
                    
                    // Frequency features (simplified FFT)
                    const fft = this.simpleFFT(segment);
                    const dominantFreq = this.findDominantFrequency(fft, sampleRate);
                    
                    // Temporal features
                    const zeroCrossings = this.countZeroCrossings(segment);
                    const energy = segment.reduce((a,b) => a + b*b, 0);
                    
                    // Peak features
                    const peaks = this.findPeaks(segment);
                    const peakCount = peaks.length;
                    const avgPeakHeight = peaks.reduce((a,p) => a + p.value, 0) / (peakCount || 1);
                    
                    // Entropy (signal complexity)
                    const entropy = this.calculateEntropy(segment);
                    
                    // Autocorrelation (periodicity)
                    const autocorr = this.autocorrelation(segment, 10);
                    
                    return {
                        mean,
                        std,
                        variance,
                        dominantFreq,
                        zeroCrossings,
                        energy,
                        peakCount,
                        avgPeakHeight,
                        entropy,
                        autocorr,
                        // Raw feature vector for GNN
                        vector: [
                            mean / 100,                    // Normalize
                            std / 50,
                            dominantFreq / (sampleRate/2),
                            zeroCrossings / segment.length,
                            Math.log10(energy + 1) / 10,
                            peakCount / 10,
                            avgPeakHeight / 100,
                            entropy / 8,
                            autocorr
                        ]
                    };
                });
            }
            
            // Build k-NN graph based on feature similarity
            buildKNNGraph(k) {
                const n = this.nodes.length;
                this.adjacencyMatrix = Array(n).fill().map(() => Array(n).fill(0));
                this.edges = [];
                
                // Compute pairwise distances
                for (let i = 0; i < n; i++) {
                    const distances = [];
                    for (let j = 0; j < n; j++) {
                        if (i === j) continue;
                        
                        // Euclidean distance between feature vectors
                        const dist = this.euclideanDistance(
                            this.nodeFeatures[i].vector,
                            this.nodeFeatures[j].vector
                        );
                        distances.push({idx: j, dist});
                    }
                    
                    // Sort by distance and keep k nearest
                    distances.sort((a,b) => a.dist - b.dist);
                    
                    for (let m = 0; m < Math.min(k, distances.length); m++) {
                        const j = distances[m].idx;
                        const similarity = 1 / (1 + distances[m].dist); // Convert distance to similarity
                        
                        this.adjacencyMatrix[i][j] = similarity;
                        this.edges.push({
                            from: i,
                            to: j,
                            weight: similarity,
                            distance: distances[m].dist
                        });
                    }
                }
                
                // Make symmetric (undirected graph)
                for (let i = 0; i < n; i++) {
                    for (let j = i+1; j < n; j++) {
                        if (this.adjacencyMatrix[i][j] > 0 || this.adjacencyMatrix[j][i] > 0) {
                            const weight = Math.max(this.adjacencyMatrix[i][j], this.adjacencyMatrix[j][i]);
                            this.adjacencyMatrix[i][j] = weight;
                            this.adjacencyMatrix[j][i] = weight;
                        }
                    }
                }
            }
            
            // Compute graph properties
            computeGraphProperties() {
                const n = this.nodes.length;
                
                // Degree matrix
                this.degreeMatrix = Array(n).fill().map(() => Array(n).fill(0));
                for (let i = 0; i < n; i++) {
                    let degree = 0;
                    for (let j = 0; j < n; j++) {
                        degree += this.adjacencyMatrix[i][j] > 0 ? 1 : 0;
                    }
                    this.degreeMatrix[i][i] = degree;
                }
                
                // Laplacian matrix: L = D - A
                this.laplacian = Array(n).fill().map(() => Array(n).fill(0));
                for (let i = 0; i < n; i++) {
                    for (let j = 0; j < n; j++) {
                        this.laplacian[i][j] = this.degreeMatrix[i][j] - this.adjacencyMatrix[i][j];
                    }
                }
                
                // Graph statistics
                this.graphStats = {
                    numNodes: n,
                    numEdges: this.edges.length,
                    density: (2 * this.edges.length) / (n * (n - 1)),
                    avgDegree: (2 * this.edges.length) / n,
                    isConnected: this.checkConnectivity()
                };
            }
            
            // Detect communities using spectral clustering
            detectCommunities() {
                // Simplified Louvain-like community detection
                const n = this.nodes.length;
                this.communities = [];
                
                // Group nodes by connectivity patterns
                const visited = new Array(n).fill(false);
                
                for (let i = 0; i < n; i++) {
                    if (visited[i]) continue;
                    
                    const community = [];
                    const queue = [i];
                    visited[i] = true;
                    
                    while (queue.length > 0) {
                        const node = queue.shift();
                        community.push(node);
                        
                        for (let j = 0; j < n; j++) {
                            if (!visited[j] && this.adjacencyMatrix[node][j] > 0) {
                                visited[j] = true;
                                queue.push(j);
                            }
                        }
                    }
                    
                    if (community.length > 1) {
                        this.communities.push(community);
                    }
                }
                
                // If no communities found, create artificial ones based on feature similarity
                if (this.communities.length === 0) {
                    this.communities = this.spectralClustering(5); // 5 communities
                }
            }
            
            // Spectral clustering for community detection
            spectralClustering(numClusters) {
                const n = this.nodes.length;
                
                // Compute normalized Laplacian: L_norm = D^(-1/2) * L * D^(-1/2)
                const L_norm = Array(n).fill().map(() => Array(n).fill(0));
                for (let i = 0; i < n; i++) {
                    for (let j = 0; j < n; j++) {
                        if (this.degreeMatrix[i][i] > 0 && this.degreeMatrix[j][j] > 0) {
                            L_norm[i][j] = this.laplacian[i][j] / 
                                Math.sqrt(this.degreeMatrix[i][i] * this.degreeMatrix[j][j] || 1);
                        }
                    }
                }
                
                // Simplified eigen-decomposition (using power iteration)
                const eigenvectors = this.powerIteration(L_norm, numClusters);
                
                // K-means on eigenvectors
                return this.kMeansClustering(eigenvectors, numClusters);
            }
            
            // Generate 3D embeddings for visualization using force-directed layout
            generateEmbeddings() {
                const n = this.nodes.length;
                
                // Initialize random positions
                this.nodeEmbeddings = Array(n).fill().map(() => ({
                    x: (Math.random() - 0.5) * 4,
                    y: (Math.random() - 0.5) * 4,
                    z: (Math.random() - 0.5) * 4
                }));
                
                // Force-directed layout (simulated annealing)
                const iterations = 100;
                const k = 0.5; // Spring constant
                const repulsion = 0.1;
                
                for (let iter = 0; iter < iterations; iter++) {
                    const temperature = 1 - iter / iterations;
                    
                    // Compute forces
                    const forces = Array(n).fill().map(() => ({fx: 0, fy: 0, fz: 0}));
                    
                    // Repulsion between all nodes
                    for (let i = 0; i < n; i++) {
                        for (let j = i+1; j < n; j++) {
                            const dx = this.nodeEmbeddings[i].x - this.nodeEmbeddings[j].x;
                            const dy = this.nodeEmbeddings[i].y - this.nodeEmbeddings[j].y;
                            const dz = this.nodeEmbeddings[i].z - this.nodeEmbeddings[j].z;
                            
                            const dist = Math.sqrt(dx*dx + dy*dy + dz*dz) + 0.01;
                            const force = repulsion / (dist * dist);
                            
                            forces[i].fx += dx * force / dist;
                            forces[i].fy += dy * force / dist;
                            forces[i].fz += dz * force / dist;
                            
                            forces[j].fx -= dx * force / dist;
                            forces[j].fy -= dy * force / dist;
                            forces[j].fz -= dz * force / dist;
                        }
                    }
                    
                    // Attraction along edges
                    this.edges.forEach(edge => {
                        const i = edge.from;
                        const j = edge.to;
                        
                        const dx = this.nodeEmbeddings[j].x - this.nodeEmbeddings[i].x;
                        const dy = this.nodeEmbeddings[j].y - this.nodeEmbeddings[i].y;
                        const dz = this.nodeEmbeddings[j].z - this.nodeEmbeddings[i].z;
                        
                        const dist = Math.sqrt(dx*dx + dy*dy + dz*dz) + 0.01;
                        const force = k * edge.weight * dist;
                        
                        forces[i].fx += dx * force / dist;
                        forces[i].fy += dy * force / dist;
                        forces[i].fz += dz * force / dist;
                        
                        forces[j].fx -= dx * force / dist;
                        forces[j].fy -= dy * force / dist;
                        forces[j].fz -= dz * force / dist;
                    });
                    
                    // Apply forces with temperature
                    for (let i = 0; i < n; i++) {
                        this.nodeEmbeddings[i].x += forces[i].fx * temperature * 0.1;
                        this.nodeEmbeddings[i].y += forces[i].fy * temperature * 0.1;
                        this.nodeEmbeddings[i].z += forces[i].fz * temperature * 0.1;
                    }
                }
                
                return this.nodeEmbeddings;
            }
            
            // GNN forward pass (simulated)
            gnnForwardPass() {
                // Simplified GNN layer: H^{(l+1)} = σ( D̂^{-1/2} Â D̂^{-1/2} H^{(l)} W^{(l)} )
                
                const n = this.nodes.length;
                
                // Input features (from nodeFeatures)
                let H = this.nodeFeatures.map(f => f.vector);
                
                // Layer 1
                const A_hat = this.addSelfLoops(this.adjacencyMatrix);
                const D_hat = this.computeDegreeMatrix(A_hat);
                const D_inv_sqrt = this.computeInverseSqrt(D_hat);
                
                // Normalized adjacency: A_norm = D̂^{-1/2} Â D̂^{-1/2}
                const A_norm = this.multiplyMatrices(
                    this.multiplyMatrices(D_inv_sqrt, A_hat),
                    D_inv_sqrt
                );
                
                // H1 = ReLU(A_norm @ H @ W1)
                let H1 = this.multiplyMatrices(A_norm, H);
                H1 = this.multiplyMatrices(H1, this.W1);
                H1 = H1.map(row => row.map(x => Math.max(0, x))); // ReLU
                
                // Layer 2
                let H2 = this.multiplyMatrices(A_norm, H1);
                H2 = this.multiplyMatrices(H2, this.W2);
                H2 = H2.map(row => row.map(x => Math.max(0, x)));
                
                // Layer 3 (output)
                let H3 = this.multiplyMatrices(A_norm, H2);
                H3 = this.multiplyMatrices(H3, this.W3);
                
                // Output embeddings
                return H3;
            }
            
            // ==================== UTILITY FUNCTIONS ====================
            
            simpleFFT(segment) {
                // Simplified FFT for feature extraction
                const n = segment.length;
                const result = [];
                for (let k = 0; k < n/2; k++) {
                    let real = 0;
                    let imag = 0;
                    for (let t = 0; t < n; t++) {
                        const angle = (2 * Math.PI * k * t) / n;
                        real += segment[t] * Math.cos(angle);
                        imag -= segment[t] * Math.sin(angle);
                    }
                    result.push(Math.sqrt(real*real + imag*imag) / n);
                }
                return result;
            }
            
            findDominantFrequency(fft, sampleRate) {
                let maxIdx = 0;
                for (let i = 1; i < fft.length; i++) {
                    if (fft[i] > fft[maxIdx]) maxIdx = i;
                }
                return (maxIdx * sampleRate) / (2 * fft.length);
            }
            
            countZeroCrossings(segment) {
                let count = 0;
                for (let i = 1; i < segment.length; i++) {
                    if ((segment[i-1] >= 0 && segment[i] < 0) || 
                        (segment[i-1] < 0 && segment[i] >= 0)) {
                        count++;
                    }
                }
                return count;
            }
            
            findPeaks(segment) {
                const peaks = [];
                for (let i = 1; i < segment.length-1; i++) {
                    if (segment[i] > segment[i-1] && segment[i] > segment[i+1]) {
                        peaks.push({index: i, value: segment[i]});
                    }
                }
                return peaks;
            }
            
            calculateEntropy(segment) {
                const hist = new Array(10).fill(0);
                const min = Math.min(...segment);
                const max = Math.max(...segment);
                const range = max - min;
                
                segment.forEach(v => {
                    const bin = Math.floor(((v - min) / range) * 9);
                    hist[Math.min(bin, 9)]++;
                });
                
                let entropy = 0;
                hist.forEach(count => {
                    const p = count / segment.length;
                    if (p > 0) entropy -= p * Math.log2(p);
                });
                
                return entropy;
            }
            
            autocorrelation(segment, maxLag) {
                const mean = segment.reduce((a,b) => a + b, 0) / segment.length;
                const centered = segment.map(v => v - mean);
                const variance = centered.reduce((a,b) => a + b*b, 0);
                
                let maxCorr = 0;
                for (let lag = 1; lag < maxLag; lag++) {
                    let corr = 0;
                    for (let i = 0; i < segment.length - lag; i++) {
                        corr += centered[i] * centered[i + lag];
                    }
                    corr /= variance;
                    maxCorr = Math.max(maxCorr, corr);
                }
                return maxCorr;
            }
            
            euclideanDistance(v1, v2) {
                let sum = 0;
                for (let i = 0; i < v1.length; i++) {
                    sum += Math.pow(v1[i] - v2[i], 2);
                }
                return Math.sqrt(sum);
            }
            
            checkConnectivity() {
                const n = this.nodes.length;
                const visited = new Array(n).fill(false);
                const stack = [0];
                visited[0] = true;
                
                while (stack.length > 0) {
                    const node = stack.pop();
                    for (let j = 0; j < n; j++) {
                        if (!visited[j] && this.adjacencyMatrix[node][j] > 0) {
                            visited[j] = true;
                            stack.push(j);
                        }
                    }
                }
                
                return visited.every(v => v);
            }
            
            powerIteration(matrix, k) {
                // Simplified power iteration for eigenvectors
                const n = matrix.length;
                const vectors = [];
                
                for (let i = 0; i < k; i++) {
                    let v = Array(n).fill().map(() => Math.random());
                    
                    for (let iter = 0; iter < 50; iter++) {
                        // Multiply by matrix
                        const v_new = Array(n).fill(0);
                        for (let j = 0; j < n; j++) {
                            for (let l = 0; l < n; l++) {
                                v_new[j] += matrix[j][l] * v[l];
                            }
                        }
                        
                        // Normalize
                        const norm = Math.sqrt(v_new.reduce((a,b) => a + b*b, 0));
                        v = v_new.map(x => x / norm);
                    }
                    vectors.push(v);
                }
                
                return vectors;
            }
            
            kMeansClustering(vectors, k) {
                const n = vectors[0].length;
                const clusters = Array(n).fill().map(() => []);
                
                // Random centroids
                const centroids = Array(k).fill().map(() => 
                    Array(vectors.length).fill().map(() => Math.random())
                );
                
                for (let iter = 0; iter < 20; iter++) {
                    // Assign points to nearest centroid
                    const assignments = Array(n).fill(0);
                    for (let i = 0; i < n; i++) {
                        let minDist = Infinity;
                        for (let c = 0; c < k; c++) {
                            let dist = 0;
                            for (let d = 0; d < vectors.length; d++) {
                                dist += Math.pow(vectors[d][i] - centroids[c][d], 2);
                            }
                            if (dist < minDist) {
                                minDist = dist;
                                assignments[i] = c;
                            }
                        }
                        clusters[assignments[i]].push(i);
                    }
                    
                    // Update centroids
                    for (let c = 0; c < k; c++) {
                        if (clusters[c].length === 0) continue;
                        for (let d = 0; d < vectors.length; d++) {
                            let sum = 0;
                            clusters[c].forEach(idx => {
                                sum += vectors[d][idx];
                            });
                            centroids[c][d] = sum / clusters[c].length;
                        }
                    }
                }
                
                return clusters.filter(c => c.length > 0);
            }
            
            addSelfLoops(adj) {
                const n = adj.length;
                const result = adj.map(row => [...row]);
                for (let i = 0; i < n; i++) {
                    result[i][i] = 1;
                }
                return result;
            }
            
            computeDegreeMatrix(adj) {
                const n = adj.length;
                const D = Array(n).fill().map(() => Array(n).fill(0));
                for (let i = 0; i < n; i++) {
                    let degree = 0;
                    for (let j = 0; j < n; j++) {
                        degree += adj[i][j];
                    }
                    D[i][i] = degree;
                }
                return D;
            }
            
            computeInverseSqrt(D) {
                const n = D.length;
                const result = Array(n).fill().map(() => Array(n).fill(0));
                for (let i = 0; i < n; i++) {
                    if (D[i][i] > 0) {
                        result[i][i] = 1 / Math.sqrt(D[i][i]);
                    }
                }
                return result;
            }
            
            multiplyMatrices(A, B) {
                if (!Array.isArray(A[0])) {
                    // A is vector, B is matrix
                    const m = B.length;
                    const n = B[0].length;
                    const result = Array(n).fill(0);
                    for (let j = 0; j < n; j++) {
                        for (let i = 0; i < m; i++) {
                            result[j] += A[i] * B[i][j];
                        }
                    }
                    return result;
                }
                
                const m = A.length;
                const n = B[0].length;
                const p = B.length;
                const result = Array(m).fill().map(() => Array(n).fill(0));
                
                for (let i = 0; i < m; i++) {
                    for (let j = 0; j < n; j++) {
                        for (let k = 0; k < p; k++) {
                            result[i][j] += A[i][k] * B[k][j];
                        }
                    }
                }
                return result;
            }
            
            randomMatrix(rows, cols) {
                return Array(rows).fill().map(() => 
                    Array(cols).fill().map(() => (Math.random() - 0.5) * 0.1)
                );
            }
        }

        // ==================== 3D VISUALIZATION ====================

        let gnnInstance = null;
        let gnnScene, gnnCamera, gnnRenderer, gnnGroup;
        let worldScene, worldCamera, worldRenderer, worldGroup;

        function initGNN() {
            const container = document.getElementById('geo-container');
            if (!container) return;
            
            // Generate a test signal (replace with actual signal from domain)
            const testSignal = Array.from({length: 1000}, (_, i) => 
                50 + 30 * Math.sin(i * 0.1) + 10 * Math.sin(i * 0.5) + 5 * Math.random()
            );
            
            // Build real GNN from signal
            gnnInstance = new XRAG_GNN();
            const stats = gnnInstance.buildFromSignal(testSignal, 1000);
            
            // Setup Three.js scene
            gnnScene = new THREE.Scene();
            gnnScene.background = new THREE.Color(0x111111);
            
            gnnCamera = new THREE.PerspectiveCamera(45, container.clientWidth/container.clientHeight, 0.1, 1000);
            gnnCamera.position.set(6, 4, 8);
            gnnCamera.lookAt(0, 0, 0);
            
            gnnRenderer = new THREE.WebGLRenderer({ antialias: true });
            gnnRenderer.setSize(container.clientWidth, container.clientHeight);
            gnnRenderer.setPixelRatio(window.devicePixelRatio);
            container.innerHTML = '';
            container.appendChild(gnnRenderer.domElement);
            
            // Lighting
            const ambientLight = new THREE.AmbientLight(0x404060);
            gnnScene.add(ambientLight);
            
            const light1 = new THREE.PointLight(0x00ff88, 1);
            light1.position.set(10, 10, 10);
            gnnScene.add(light1);
            
            const light2 = new THREE.PointLight(0xff44aa, 0.5);
            light2.position.set(-10, -5, -10);
            gnnScene.add(light2);
            
            gnnGroup = new THREE.Group();
            
            // Colors for communities
            const colors = [0x00ff88, 0xff4444, 0x4a90e2, 0xffaa00, 0xaa44ff];
            
            // Create nodes with community colors
            gnnInstance.nodeEmbeddings.forEach((pos, i) => {
                // Find community for this node
                let communityColor = colors[0];
                for (let c = 0; c < gnnInstance.communities.length; c++) {
                    if (gnnInstance.communities[c].includes(i)) {
                        communityColor = colors[c % colors.length];
                        break;
                    }
                }
                
                const geometry = new THREE.SphereGeometry(0.15, 16);
                const material = new THREE.MeshStandardMaterial({ 
                    color: communityColor,
                    emissive: communityColor,
                    emissiveIntensity: 0.3
                });
                const sphere = new THREE.Mesh(geometry, material);
                sphere.position.set(pos.x, pos.y, pos.z);
                gnnGroup.add(sphere);
            });
            
            // Create edges with opacity based on weight
            const edgeMaterial = new THREE.LineBasicMaterial({ color: 0x00ff88, opacity: 0.2, transparent: true });
            
            gnnInstance.edges.forEach(edge => {
                const from = gnnInstance.nodeEmbeddings[edge.from];
                const to = gnnInstance.nodeEmbeddings[edge.to];
                
                const points = [
                    new THREE.Vector3(from.x, from.y, from.z),
                    new THREE.Vector3(to.x, to.y, to.z)
                ];
                const geometry = new THREE.BufferGeometry().setFromPoints(points);
                const line = new THREE.Line(geometry, edgeMaterial);
                gnnGroup.add(line);
            });
            
            gnnScene.add(gnnGroup);
            
            // Update stats display
            document.getElementById('geo-nodes').textContent = stats.nodes;
            document.getElementById('geo-edges').textContent = stats.edges;
            document.getElementById('geo-communities').textContent = stats.communities;
        }

        // ==================== WORLD DIGITAL TWIN ====================

        function initWorld() {
            const container = document.getElementById('world-container');
            if (!container) return;
            
            worldScene = new THREE.Scene();
            worldScene.background = new THREE.Color(0x111111);
            
            worldCamera = new THREE.PerspectiveCamera(45, container.clientWidth/container.clientHeight, 0.1, 1000);
            worldCamera.position.set(3, 2, 5);
            
            worldRenderer = new THREE.WebGLRenderer({ antialias: true });
            worldRenderer.setSize(container.clientWidth, container.clientHeight);
            worldRenderer.setPixelRatio(window.devicePixelRatio);
            container.innerHTML = '';
            container.appendChild(worldRenderer.domElement);
            
            const light = new THREE.PointLight(0x00ff88, 1);
            light.position.set(5, 5, 5);
            worldScene.add(light);
            
            worldGroup = new THREE.Group();
            
            // Base platform
            const baseGeo = new THREE.BoxGeometry(3, 0.2, 2);
            const baseMat = new THREE.MeshStandardMaterial({ color: 0x444444 });
            const base = new THREE.Mesh(baseGeo, baseMat);
            base.position.y = -0.5;
            worldGroup.add(base);
            
            // Cylinders (representing components)
            for (let i = -1; i <= 1; i+=1) {
                const cylGeo = new THREE.CylinderGeometry(0.3, 0.3, 1, 16);
                const cylMat = new THREE.MeshStandardMaterial({ color: 0x00ff88 });
                const cyl = new THREE.Mesh(cylGeo, cylMat);
                cyl.position.set(i, 0.2, 0);
                worldGroup.add(cyl);
            }
            
            worldScene.add(worldGroup);
            
            // Temperature slider control
            document.getElementById('world-temp').addEventListener('input', (e) => {
                const val = e.target.value;
                document.getElementById('world-temp-display').textContent = val + '°C';
                if (worldGroup) {
                    worldGroup.children.forEach(child => {
                        if (child.material && child.material.color) {
                            const hue = val / 200;
                            child.material.color.setHSL(hue, 1, 0.5);
                        }
                    });
                }
            });
            
            // Pressure slider control
            document.getElementById('world-pressure').addEventListener('input', (e) => {
                document.getElementById('world-pressure-display').textContent = e.target.value + '%';
            });
        }

        // ==================== ANIMATION LOOP ====================

        function animate() {
            requestAnimationFrame(animate);
            
            if (gnnGroup) {
                gnnGroup.rotation.y += 0.001;
            }
            
            if (gnnRenderer && gnnScene && gnnCamera) {
                gnnRenderer.render(gnnScene, gnnCamera);
            }
            
            if (worldRenderer && worldScene && worldCamera) {
                worldRenderer.render(worldScene, worldCamera);
            }
        }

        // ==================== DOMAIN MANAGEMENT ====================

        const domains = [
            { id: 'physics', name: 'Physics', count: 65, icon: '⚛️' },
            { id: 'electrical', name: 'Electrical', count: 52, icon: '⚡' },
            { id: 'mechanical', name: 'Mechanical', count: 48, icon: '🔧' }
        ];

        document.addEventListener('DOMContentLoaded', function() {
            loadDomains();
            initGNN();
            initWorld();
            animate();
        });

        function loadDomains() {
            const list = document.getElementById('domain-list');
            list.innerHTML = domains.map(d => 
                `<li class="domain-item" onclick="selectDomain('${d.id}', this)">${d.icon} ${d.name} <span class="count">${d.count}</span></li>`
            ).join('');
            if (domains.length > 0) {
                selectDomain(domains[0].id, list.firstChild);
            }
        }

        function selectDomain(domainId, element) {
            document.querySelectorAll('.domain-item').forEach(el => el.classList.remove('active'));
            if (element) element.classList.add('active');
            document.getElementById('upasl-domain').textContent = domainId;
        }

        // ==================== TAB SWITCHING ====================

        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            
            document.getElementById('core-view').style.display = tab === 'core' ? 'block' : 'none';
            document.getElementById('geo-view').style.display = tab === 'geo' ? 'block' : 'none';
            document.getElementById('world-view').style.display = tab === 'world' ? 'block' : 'none';
            document.getElementById('causal-view').style.display = tab === 'causal' ? 'block' : 'none';
            document.getElementById('statistical-view').style.display = tab === 'statistical' ? 'block' : 'none';
            document.getElementById('engineering-view').style.display = tab === 'engineering' ? 'block' : 'none';
        }

        // ==================== MODAL FUNCTIONS ====================

        function openModal(type) {
            document.getElementById('modal').classList.add('active');
            document.getElementById('modal-title').textContent = type.toUpperCase() + ' - Enlarged View';
        }

        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }

        function exportFreezePackage() {
            alert('Freeze package exported');
        }

        // Expose to global
        window.selectDomain = selectDomain;
        window.switchTab = switchTab;
        window.openModal = openModal;
        window.closeModal = closeModal;
        window.exportFreezePackage = exportFreezePackage;
    </script>
</body>
</html>
